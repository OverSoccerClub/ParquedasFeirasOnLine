# ============================================================
# Parque das Feiras — Dockerfile.web (Frontend React)
# Build: Vite + React + TypeScript
# Serve: Nginx
# ============================================================

# ---- Stage 1: Build ----
FROM node:20-alpine AS builder

WORKDIR /app

COPY frontend/package*.json ./
RUN npm ci --prefer-offline

COPY frontend/ .

ARG VITE_API_URL=https://api.parquedasfeiras.com.br
ARG VITE_APP_NAME="Parque das Feiras"
ARG VITE_MERCADOPAGO_PUBLIC_KEY=""

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_APP_NAME=$VITE_APP_NAME
ENV VITE_MERCADOPAGO_PUBLIC_KEY=$VITE_MERCADOPAGO_PUBLIC_KEY

RUN npm run build

# ---- Stage 2: Serve ----
FROM nginx:1.25-alpine AS runner

RUN rm /etc/nginx/conf.d/default.conf

COPY --from=builder /app/dist /usr/share/nginx/html
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
