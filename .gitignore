# ============================================================
# .gitignore — Parque das Feiras
# ============================================================

# Node
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
frontend/dist/
backend/dist/

# Variáveis de ambiente (NUNCA commitar)
.env
.env.local
.env.production
.env.staging
**/.env
**/.env.local
**/.env.production

# Prisma migrations geradas localmente (manter apenas as committed)
# backend/prisma/migrations/ # manter no git

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
logs/

# Coverage
coverage/
*.lcov

# Cache
.cache/
.turbo/
*.tsbuildinfo

# Uploads locais
backend/uploads/
