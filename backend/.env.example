# ============================================================
# Parque das Feiras API — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ============================================================

NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/parque_feiras"

# JWT (gere com: openssl rand -base64 64)
JWT_SECRET=sua_chave_jwt_super_secreta_aqui
JWT_REFRESH_SECRET=sua_chave_refresh_super_secreta_aqui

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_aqui
MERCADOPAGO_WEBHOOK_SECRET=seu_webhook_secret

# CORS (origens permitidas, separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,https://parquedasfeiras.com.br

# Storage de imagens (S3 ou Cloudflare R2)
STORAGE_BUCKET=parque-das-feiras
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
