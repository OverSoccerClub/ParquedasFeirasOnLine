// ============================================================
// Parque das Feiras — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  buyer
  seller
  admin
}

enum UserStatus {
  active
  inactive
  suspended
  pending_verification
}

enum StoreStatus {
  pending
  active
  suspended
  closed
}

enum ProductStatus {
  draft
  active
  inactive
  sold_out
  pending_review
}

enum OrderStatus {
  pending_payment
  payment_confirmed
  preparing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentMethod {
  pix
  credit_card
  debit_card
  boleto
}

enum PaymentStatus {
  pending
  processing
  approved
  rejected
  refunded
  expired
}

enum TransactionType {
  sale
  refund
  withdrawal
  fee
  adjustment
}

enum TransactionStatus {
  pending
  available
  transferred
  cancelled
}

// ============================================================
// USUÁRIOS
// ============================================================

model User {
  id               String     @id @default(uuid())
  name             String     @db.VarChar(150)
  email            String     @unique @db.VarChar(255)
  phone            String?    @db.VarChar(20)
  passwordHash     String     @map("password_hash") @db.VarChar(255)
  role             UserRole   @default(buyer)
  status           UserStatus @default(pending_verification)
  avatarUrl        String?    @map("avatar_url")
  cpfCnpj          String?    @unique @map("cpf_cnpj") @db.VarChar(18)
  emailVerifiedAt  DateTime?  @map("email_verified_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  addresses    UserAddress[]
  store        Store?
  orders       Order[]
  reviews      ProductReview[]
  wishlist     Wishlist[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model UserAddress {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  label         String?  @default("Casa") @db.VarChar(50)
  recipientName String   @map("recipient_name") @db.VarChar(150)
  zipCode       String   @map("zip_code") @db.VarChar(9)
  street        String   @db.VarChar(200)
  number        String   @db.VarChar(20)
  complement    String?  @db.VarChar(100)
  neighborhood  String   @db.VarChar(100)
  city          String   @db.VarChar(100)
  state         String   @db.Char(2)
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_addresses")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ============================================================
// LOJAS
// ============================================================

model Store {
  id                  String      @id @default(uuid())
  ownerId             String      @unique @map("owner_id")
  name                String      @db.VarChar(150)
  slug                String      @unique @db.VarChar(200)
  description         String?     @db.Text
  logoUrl             String?     @map("logo_url")
  bannerUrl           String?     @map("banner_url")
  phone               String?     @db.VarChar(20)
  whatsapp            String?     @db.VarChar(20)
  boxNumber           String?     @map("box_number") @db.VarChar(20)
  status              StoreStatus @default(pending)
  isWholesaleEnabled  Boolean     @default(false) @map("is_wholesale_enabled")
  rating              Decimal     @default(0) @db.Decimal(2, 1)
  totalSales          Int         @default(0) @map("total_sales")
  commissionRate      Decimal     @default(5.00) @map("commission_rate") @db.Decimal(4, 2)
  cnpj                String?     @db.VarChar(18)
  bankInfo            Json?       @map("bank_info")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  owner        User               @relation(fields: [ownerId], references: [id])
  products     Product[]
  orderStores  OrderStore[]
  transactions StoreTransaction[]

  @@map("stores")
}

// ============================================================
// PRODUTOS
// ============================================================

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(100)
  slug      String     @unique @db.VarChar(120)
  parentId  Int?       @map("parent_id")
  icon      String?    @db.VarChar(50)
  imageUrl  String?    @map("image_url")
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")

  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")
  products Product[]

  @@map("categories")
}

model Product {
  id                   String        @id @default(uuid())
  storeId              String        @map("store_id")
  categoryId           Int?          @map("category_id")
  name                 String        @db.VarChar(300)
  slug                 String        @unique @db.VarChar(350)
  description          String?       @db.Text
  status               ProductStatus @default(draft)
  price                Decimal       @db.Decimal(10, 2)
  originalPrice        Decimal?      @map("original_price") @db.Decimal(10, 2)
  isWholesaleAvailable Boolean       @default(false) @map("is_wholesale_available")
  wholesalePrice       Decimal?      @map("wholesale_price") @db.Decimal(10, 2)
  wholesaleMinQty      Int?          @default(12) @map("wholesale_min_qty")
  stockQty             Int           @default(0) @map("stock_qty")
  rating               Decimal       @default(0) @db.Decimal(2, 1)
  reviewCount          Int           @default(0) @map("review_count")
  salesCount           Int           @default(0) @map("sales_count")
  viewCount            Int           @default(0) @map("view_count")
  metaTitle            String?       @map("meta_title") @db.VarChar(200)
  metaDescription      String?       @map("meta_description") @db.Text
  tags                 String[]
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  store      Store            @relation(fields: [storeId], references: [id])
  category   Category?        @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  reviews    ProductReview[]
  wishlist   Wishlist[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  url       String  @db.Text
  altText   String? @map("alt_text") @db.VarChar(200)
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVariant {
  id            String  @id @default(uuid())
  productId     String  @map("product_id")
  size          String? @db.VarChar(20)
  color         String? @db.VarChar(50)
  colorHex      String? @map("color_hex") @db.VarChar(7)
  sku           String? @db.VarChar(100)
  stockQty      Int     @default(0) @map("stock_qty")
  priceModifier Decimal @default(0) @map("price_modifier") @db.Decimal(10, 2)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variants")
}

// ============================================================
// CARRINHO
// ============================================================

model Cart {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  sessionId String?  @map("session_id") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id          String   @id @default(uuid())
  cartId      String   @map("cart_id")
  productId   String   @map("product_id")
  variantId   String?  @map("variant_id")
  quantity    Int      @default(1)
  isWholesale Boolean  @default(false) @map("is_wholesale")
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("cart_items")
}

// ============================================================
// PEDIDOS
// ============================================================

model Order {
  id              String        @id @default(uuid())
  buyerId         String        @map("buyer_id")
  status          OrderStatus   @default(pending_payment)
  shippingAddress Json          @map("shipping_address")
  subtotal        Decimal       @db.Decimal(10, 2)
  shippingTotal   Decimal       @default(0) @map("shipping_total") @db.Decimal(10, 2)
  discountTotal   Decimal       @default(0) @map("discount_total") @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  paymentMethod   PaymentMethod? @map("payment_method")
  paymentStatus   PaymentStatus @default(pending) @map("payment_status")
  paymentId       String?       @map("payment_id") @db.VarChar(200)
  pixQrCode       String?       @map("pix_qr_code") @db.Text
  pixExpiration   DateTime?     @map("pix_expiration")
  paidAt          DateTime?     @map("paid_at")
  buyerNotes      String?       @map("buyer_notes") @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  buyer       User         @relation(fields: [buyerId], references: [id])
  orderStores OrderStore[]

  @@map("orders")
}

model OrderStore {
  id              String      @id @default(uuid())
  orderId         String      @map("order_id")
  storeId         String      @map("store_id")
  status          OrderStatus @default(pending_payment)
  subtotal        Decimal     @db.Decimal(10, 2)
  shipping        Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  commissionAmount Decimal    @map("commission_amount") @db.Decimal(10, 2)
  sellerAmount    Decimal     @map("seller_amount") @db.Decimal(10, 2)
  trackingCode    String?     @map("tracking_code") @db.VarChar(100)
  shippedAt       DateTime?   @map("shipped_at")
  deliveredAt     DateTime?   @map("delivered_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  order       Order       @relation(fields: [orderId], references: [id])
  store       Store       @relation(fields: [storeId], references: [id])
  items       OrderItem[]
  transaction StoreTransaction?

  @@map("order_stores")
}

model OrderItem {
  id              String   @id @default(uuid())
  orderStoreId    String   @map("order_store_id")
  productId       String   @map("product_id")
  variantId       String?  @map("variant_id")
  quantity        Int
  unitPrice       Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalPrice      Decimal  @map("total_price") @db.Decimal(10, 2)
  isWholesale     Boolean  @default(false) @map("is_wholesale")
  productSnapshot Json     @map("product_snapshot")

  orderStore OrderStore      @relation(fields: [orderStoreId], references: [id])
  product    Product         @relation(fields: [productId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  review     ProductReview?

  @@map("order_items")
}

// ============================================================
// AVALIAÇÕES E FAVORITOS
// ============================================================

model ProductReview {
  id                String   @id @default(uuid())
  productId         String   @map("product_id")
  buyerId           String   @map("buyer_id")
  orderItemId       String?  @unique @map("order_item_id")
  rating            Int
  title             String?  @db.VarChar(200)
  comment           String?  @db.Text
  images            String[]
  isVerifiedPurchase Boolean @default(false) @map("is_verified_purchase")
  isApproved        Boolean  @default(false) @map("is_approved")
  createdAt         DateTime @default(now()) @map("created_at")

  product   Product    @relation(fields: [productId], references: [id])
  buyer     User       @relation(fields: [buyerId], references: [id])
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])

  @@map("product_reviews")
}

model Wishlist {
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
  @@map("wishlists")
}

// ============================================================
// FINANCEIRO
// ============================================================

model StoreTransaction {
  id           String            @id @default(uuid())
  storeId      String            @map("store_id")
  orderStoreId String?           @unique @map("order_store_id")
  type         TransactionType
  amount       Decimal           @db.Decimal(10, 2)
  fee          Decimal           @default(0) @db.Decimal(10, 2)
  netAmount    Decimal           @map("net_amount") @db.Decimal(10, 2)
  status       TransactionStatus @default(pending)
  description  String?           @db.Text
  availableAt  DateTime?         @map("available_at")
  createdAt    DateTime          @default(now()) @map("created_at")

  store      Store       @relation(fields: [storeId], references: [id])
  orderStore OrderStore? @relation(fields: [orderStoreId], references: [id])

  @@map("store_transactions")
}

// ============================================================
// BANNERS
// ============================================================

model Banner {
  id             Int       @id @default(autoincrement())
  title          String?   @db.VarChar(200)
  subtitle       String?   @db.VarChar(200)
  imageUrl       String    @map("image_url") @db.Text
  mobileImageUrl String?   @map("mobile_image_url") @db.Text
  linkUrl        String?   @map("link_url") @db.Text
  sortOrder      Int       @default(0) @map("sort_order")
  isActive       Boolean   @default(true) @map("is_active")
  startsAt       DateTime? @map("starts_at")
  endsAt         DateTime? @map("ends_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("banners")
}
